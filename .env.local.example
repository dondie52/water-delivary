# Supabase (existing)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 21st Agents — get your key at https://21st.dev/agents/app
API_KEY_21ST=21st_sk_...

