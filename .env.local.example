# Supabase (existing)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Public site URL for email confirmation links (no trailing slash).
# Production: https://water-delivary.onrender.com (or your custom domain)
# Local dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=
# In Supabase Dashboard → Authentication → URL Configuration:
#   Site URL = https://water-delivary.onrender.com
#   Redirect URLs = https://water-delivary.onrender.com/auth/callback
#   (add http://localhost:3000/auth/callback for local dev)

# 21st Agents — get your key at https://21st.dev/agents/app
API_KEY_21ST=21st_sk_...

# Google Gemini — powers the floating AI chat (free tier at https://aistudio.google.com/apikey)
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional: override model (default gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# OpenAI Videos API (Sora) - used only by npm run generate:delivery-video
OPENAI_API_KEY=
