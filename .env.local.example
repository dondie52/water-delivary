# Supabase (existing)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Public site URL for email confirmation links (no trailing slash).
# Vercel production: https://your-project.vercel.app (or your custom domain)
# Local dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=
# In Supabase Dashboard → Authentication → URL Configuration:
#   Site URL = your Vercel production URL
#   Redirect URLs:
#     https://your-project.vercel.app/auth/callback
#     http://localhost:3000/auth/callback
#   (add each Vercel preview URL if you test auth on preview deploys)

# 21st Agents — get your key at https://21st.dev/agents/app
API_KEY_21ST=21st_sk_...

# Google Gemini — powers the floating AI chat (free tier at https://aistudio.google.com/apikey)
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional: override model (default gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# OpenAI Videos API (Sora) - used only by npm run generate:delivery-video
OPENAI_API_KEY=
